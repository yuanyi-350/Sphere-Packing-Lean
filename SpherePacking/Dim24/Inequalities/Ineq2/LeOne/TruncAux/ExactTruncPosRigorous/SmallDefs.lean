/-- For `n < N`, the hard-coded list `coeffsSmall` agrees with the definitional coefficient
`coeffSmall n`. -/
public lemma coeffsSmall_getD_eq_coeffSmall (n : ℕ) (hn : n < N) :
    coeffsSmall.getD n 0 = coeffSmall n := by
  have hn100 : n < 100 := by simpa [N, CoeffModel.N] using hn
  by_cases h10 : n < 10
  · exact coeffsSmall_getD_eq_coeffSmall_0_9 n h10
  have h10' : 10 ≤ n := Nat.le_of_not_gt h10
  by_cases h20 : n < 20
  · exact coeffsSmall_getD_eq_coeffSmall_10_19 n h10' h20
  have h20' : 20 ≤ n := Nat.le_of_not_gt h20
  by_cases h30 : n < 30
  · exact coeffsSmall_getD_eq_coeffSmall_20_29 n h20' h30
  have h30' : 30 ≤ n := Nat.le_of_not_gt h30
  by_cases h40 : n < 40
  · exact coeffsSmall_getD_eq_coeffSmall_30_39 n h30' h40
  have h40' : 40 ≤ n := Nat.le_of_not_gt h40
  by_cases h50 : n < 50
  · exact coeffsSmall_getD_eq_coeffSmall_40_49 n h40' h50
  have h50' : 50 ≤ n := Nat.le_of_not_gt h50
  by_cases h60 : n < 60
  · exact coeffsSmall_getD_eq_coeffSmall_50_59 n h50' h60
  have h60' : 60 ≤ n := Nat.le_of_not_gt h60
  by_cases h70 : n < 70
  · exact coeffsSmall_getD_eq_coeffSmall_60_69 n h60' h70
  have h70' : 70 ≤ n := Nat.le_of_not_gt h70
  by_cases h80 : n < 80
  · exact coeffsSmall_getD_eq_coeffSmall_70_79 n h70' h80
  have h80' : 80 ≤ n := Nat.le_of_not_gt h80
  by_cases h90 : n < 90
  · exact coeffsSmall_getD_eq_coeffSmall_80_89 n h80' h90
  have h90' : 90 ≤ n := Nat.le_of_not_gt h90
  exact coeffsSmall_getD_eq_coeffSmall_90_99 n h90' hn100

